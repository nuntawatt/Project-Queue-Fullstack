# ============================================================
# QUEUELY — Environment Variables
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development          # development | production | test

# ── Redis ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=             # ใส่ถ้า Redis ต้องการ password (production)

# ── Auth ────────────────────────────────────────────────────
API_KEY=queuely-dev-secret    # เปลี่ยนเป็น random string ยาวๆ ตอน production

# ── Worker Pool ─────────────────────────────────────────────
WORKER_CONCURRENCY=5          # จำนวน worker ที่รันพร้อมกัน
WORKER_POLL_INTERVAL_MS=500   # ความถี่ที่ worker ดึง job จาก queue (ms)
JOB_TIMEOUT_MS=30000          # เวลาสูงสุดที่ job หนึ่งจะทำงานได้ (ms)

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000    # window time (ms) — default 1 นาที
RATE_LIMIT_MAX_REQUESTS=100   # จำนวน request สูงสุดต่อ window

# ── Circuit Breaker ──────────────────────────────────────────
CB_FAILURE_THRESHOLD=5        # failure ครบเท่านี้ → circuit เปิด
CB_SUCCESS_THRESHOLD=2        # success ครบเท่านี้ (half-open) → circuit ปิด
CB_TIMEOUT_MS=10000           # รอนานเท่านี้แล้วลอง half-open (ms)

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173